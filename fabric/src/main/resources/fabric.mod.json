{
  "schemaVersion": 1,
  "id": "ores",
  "version": "${version}",
  "name": "Ores Core",
  "icon": "assets/ores/icon.png",
  "description": "Unifies the management of materials and ores for Minecraft mods",
  "authors": [
    "__mathieu"
  ],
  "contact": {},
  "license": "CC BY-NC-SA 4.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      "ores.mathieu.fabric.OresCoreFabric"
    ],
    "client": [
      "ores.mathieu.fabric.OresCoreClientFabric"
    ]
  },
  "mixins": [
    "ores.mixins.json",
    "ores.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": ">=26.1-alpha.10",
    "java": ">=25",
    "fabric-api": "*"
